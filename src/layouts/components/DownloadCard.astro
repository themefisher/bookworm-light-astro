---
import { Icon } from 'astro-icon/components'; // fallback if needed, but we'll use your custom one:
import DynamicIcon from "@/helpers/DynamicIcon";

interface Props {
  href: string;
  title: string;
  fileSize: string;
  openInNewTab?: boolean;
}

const { href, title, fileSize, openInNewTab = false } = Astro.props;

// Determine if it should open in a window or trigger a direct download
const behaviorProps = openInNewTab 
  ? { target: "_blank", rel: "noopener noreferrer" } 
  : { download: true };

const labelExtension = openInNewTab ? ", opens in a new tab" : "";
---

<a 
  href={href} 
  {...behaviorProps}
  class="group inline-flex items-center gap-4 p-4 bg-white transition-all duration-300 no-underline min-h-12 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
  aria-label={`Download ${title}, PDF file, size ${fileSize}${labelExtension}`}
>
  <div 
    aria-hidden="true" 
    class="w-8 h-8 shrink-0  group-hover:scale-110 flex items-center justify-center group-hover:text-primary"
  >
    <DynamicIcon icon="FaFilePdf" /> 
  </div>
  
  <div class="flex flex-col text-left">
    <span class="font-bold text-text group-hover:text-primary transition-colors  leading-snug">
      {title}
    </span>
    <span class="text-xs font-semibold text-slate-500 mt-0.5 tracking-wide uppercase">
      PDF &bull; {fileSize}
    </span>
  </div>
</a>