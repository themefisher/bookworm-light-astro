---
const recipes = [
  { title: "High Protein Chicken Salad", href: "/recipes/chicken-salad", image: "/images/posts/01.jpg" },
  { title: "Overnight Oats", href: "/recipes/overnight-oats", image: "/images/posts/02.jpg" },
  { title: "Garlic Butter Shrimp", href: "/recipes/garlic-butter-shrimp", image: "/images/posts/03.jpg" },
  { title: "Quinoa Buddha Bowl", href: "/recipes/quinoa-buddha-bowl", image: "/images/posts/04.jpg" },
  { title: "Turkey Meatballs", href: "/recipes/turkey-meatballs", image: "/images/posts/05.jpg" },
  { title: "Chia Seed Pudding", href: "/recipes/chia-pudding", image: "/images/posts/06.jpg" },
  { title: "Spicy Chicken Ramen", href: "/recipes/spicy-chicken-ramen", image: "/images/posts/07.jpg" },
  { title: "Baked Salmon Fillet", href: "/recipes/baked-salmon", image: "/images/posts/01.jpg" },
  { title: "Sweet Potato Soup", href: "/recipes/sweet-potato-soup", image: "/images/posts/02.jpg" },
  { title: "Greek Yogurt Parfait", href: "/recipes/greek-yogurt-parfait", image: "/images/posts/03.jpg" },
];
---
<section class="top10-section">
  <h2 class="section-heading">Top 10 Recipes</h2>
  <div class="top10-grid">
    {recipes.map((r, i) => (
      <a href={r.href} class="top10-card">
        <div class="card-img-wrap">
          <img src={r.image} alt={r.title} />
          <span class="number-badge">{i + 1}</span>
        </div>
        <p>{r.title}</p>
      </a>
    ))}
  </div>
</section>

<style>
  .top10-section {
    padding: 50px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    color: #2a2a2a;
  }
  .section-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.2;
  }
  .top10-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }
  .top10-card {
    text-decoration: none;
    border-radius: 8px;
    overflow: hidden;
    display: block;
    color: #333;
  }
  .card-img-wrap {
    position: relative;
  }
  .card-img-wrap img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    border-radius: 8px;
  }
  .number-badge {
    position: absolute;
    bottom: 10px;
    left: 10px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    background: #3a6b4f;
    color: #fff;
  }
  .top10-card p {
    text-align: center;
    padding: 10px 6px;
    font-size: 0.85rem;
    margin: 0;
    line-height: 1.4;
  }
  @media (max-width: 900px) {
    .top10-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 500px) {
    .top10-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
