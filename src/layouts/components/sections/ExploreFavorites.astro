---
const favorites = [
  { label: "Appetizers", href: "/category/appetizers", image: "/images/posts/01.jpg" },
  { label: "Breakfast",  href: "/category/breakfast",  image: "/images/posts/02.jpg" },
  { label: "Dinner",     href: "/category/dinner",     image: "/images/posts/03.jpg" },
  { label: "Side Dishes",href: "/category/sides",      image: "/images/posts/04.jpg" },
  { label: "Drinks",     href: "/category/drinks",     image: "/images/posts/05.jpg" },
  { label: "Dessert",    href: "/category/dessert",    image: "/images/posts/06.jpg" },
];
---
<section class="explore-favorites">
  <h2 class="section-heading">Explore favorites:</h2>
  <ul class="circle-list">
    {favorites.map(cat => (
      <li>
        <a href={cat.href} class="circle-link">
          <img src={cat.image} alt={cat.label} />
          <span>{cat.label}</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .explore-favorites {
    padding: 50px 24px;
    max-width: 1100px;
    margin: 0 auto;
  }
  .section-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
    color: #2a2a2a;
  }
  .section-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.2;
  }
  .circle-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .circle-link img {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 6px solid #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease;
  }
  .circle-link:hover img {
    transform: scale(1.05);
  }
  .circle-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-size: 0.85rem;
    color: #444;
    font-weight: 500;
  }
</style>
