<section class="newsletter-cta">
  <h2>High Protein Made EASY!</h2>
  <p><strong>5 days of high-protein recipes</strong> delivered to your inbox!</p>
  <a href="/subscribe" class="cta-btn">YES PLEASE →</a>
</section>

<style>
  .newsletter-cta {
    text-align: center;
    padding: 70px 24px;
    background: #e8f5ee;
  }
  .newsletter-cta h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: 12px;
    color: #2a2a2a;
  }
  .newsletter-cta p {
    font-size: 0.95rem;
    margin-bottom: 28px;
    color: #555;
  }
  .cta-btn {
    display: inline-block;
    padding: 14px 36px;
    border-radius: 50px;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    background: #3a6b4f;
    color: #fff;
    font-weight: 700;
    transition: background 0.2s;
  }
  .cta-btn:hover {
    background: #2d5540;
  }
</style>
