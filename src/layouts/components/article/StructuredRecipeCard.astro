---
const { recipe, title, image, authors = [] } = Astro.props;
const authorName = Array.isArray(authors) ? authors[0] : authors;
---
<div class="recipe-card" id="recipe-card">

  <!-- Card Header -->
  <div class="rc-header">
    {image && <img src={image} alt={title} class="rc-thumb" />}
    <div class="rc-meta">
      {authorName && <p class="rc-author">Recipe by {authorName}</p>}
      <h2 class="rc-title">{title}</h2>
      {recipe.rating && (
        <div class="rc-stars">
          {[1,2,3,4,5].map(i => (
            <span class={i <= Math.round(recipe.rating) ? "star on" : "star"}>
              {i <= Math.round(recipe.rating) ? "★" : "☆"}
            </span>
          ))}
          <span class="rc-votes">{recipe.rating?.toFixed(1)} ({recipe.votes} votes)</span>
        </div>
      )}
      <button class="rc-print" id="rc-print-btn">🖨 Print Recipe</button>
    </div>
  </div>

  <!-- Time Row -->
  {(recipe.prepTime || recipe.cookTime || recipe.totalTime) && (
    <div class="rc-times">
      {recipe.prepTime  && <div class="rc-time-item"><span class="label">Prep Time</span><span class="value">{recipe.prepTime} mins</span></div>}
      {recipe.cookTime  && <div class="rc-time-item"><span class="label">Cook Time</span><span class="value">{recipe.cookTime} mins</span></div>}
      {recipe.totalTime && <div class="rc-time-item"><span class="label">Total Time</span><span class="value">{recipe.totalTime} mins</span></div>}
    </div>
  )}

  <!-- Tag Pills -->
  <div class="rc-tags">
    {recipe.servings  && <span class="rc-tag">👥 Servings: {recipe.servings}</span>}
    {recipe.course    && <span class="rc-tag">🍽 Course: {recipe.course}</span>}
    {recipe.cuisine   && <span class="rc-tag">🌍 Cuisine: {recipe.cuisine}</span>}
    {recipe.calories  && <span class="rc-tag">🔥 Calories: {recipe.calories}</span>}
    {recipe.dietary   && <span class="rc-tag">🥗 {recipe.dietary}</span>}
  </div>

  <!-- Section Nav -->
  <nav class="rc-nav" aria-label="Recipe sections">
    {recipe.ingredients  && <a href="#rc-ingredients" class="rc-nav-item">🧂 Ingredients</a>}
    {recipe.equipment    && <a href="#rc-equipment"   class="rc-nav-item">🍳 Equipment</a>}
    {recipe.instructions && <a href="#rc-method"      class="rc-nav-item">📋 Method</a>}
    {recipe.notes        && <a href="#rc-notes"        class="rc-nav-item">📝 Notes</a>}
  </nav>

  <!-- Equipment -->
  {recipe.equipment && recipe.equipment.length > 0 && (
    <section id="rc-equipment" class="rc-section">
      <h3>Equipment</h3>
      <ul class="equipment-list">
        {recipe.equipment.map((e: { name: string; link?: string }) => (
          <li>
            {e.link
              ? <a href={e.link} target="_blank" rel="noopener">{e.name}</a>
              : e.name
            }
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Ingredients with serving multiplier -->
  {recipe.ingredients && recipe.ingredients.length > 0 && (
    <section id="rc-ingredients" class="rc-section">
      <div class="rc-ingredients-header">
        <h3>Ingredients</h3>
        <div class="serving-toggle" aria-label="Serving multiplier">
          <button class="mult-btn active" data-mult="1">1x</button>
          <button class="mult-btn" data-mult="2">2x</button>
          <button class="mult-btn" data-mult="3">3x</button>
        </div>
      </div>
      <ul class="ingredients-list" id="ingredients-list">
        {recipe.ingredients.map((ing: string, i: number) => (
          <li>
            <input type="checkbox" id={`ing-${i}`} />
            <label for={`ing-${i}`} data-original={ing}>{ing}</label>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Instructions -->
  {recipe.instructions && recipe.instructions.length > 0 && (
    <section id="rc-method" class="rc-section">
      <div class="rc-method-header">
        <h3>Instructions</h3>
        <label class="cook-mode">
          <input type="checkbox" id="cook-mode" />
          <span>Cook Mode</span>
          <small>Keep screen on</small>
        </label>
      </div>
      <ol class="instructions-list">
        {recipe.instructions.map((step: string, i: number) => (
          <li>
            <strong class="step-label">Step {i + 1}:</strong> {step}
          </li>
        ))}
      </ol>
    </section>
  )}

  <!-- Video -->
  {recipe.videoEmbed && (
    <section id="rc-video" class="rc-section">
      <h3>Video</h3>
      <div class="video-wrapper">
        <iframe src={recipe.videoEmbed} allowfullscreen loading="lazy" title={`${title} video`} />
      </div>
    </section>
  )}

  <!-- Notes -->
  {recipe.notes && (
    <section id="rc-notes" class="rc-section">
      <h3>Notes</h3>
      <div class="notes-content" set:html={recipe.notes} />
    </section>
  )}

</div>

<script>
  // ── Serving multiplier ────────────────────────────────────────────
  function scaleNumber(num: number, mult: number): string {
    const result = num * mult;
    // Keep as fraction-friendly display: round to 2 decimals, strip trailing zeros
    const rounded = Math.round(result * 100) / 100;
    return rounded % 1 === 0 ? rounded.toString() : rounded.toFixed(2).replace(/\.?0+$/, "");
  }

  function scaleIngredient(original: string, mult: number): string {
    if (mult === 1) return original;
    // Match integers and decimals (e.g. 2, 1.5, 0.5)
    return original.replace(/\b(\d+(?:\.\d+)?)\b/g, (match) => {
      return scaleNumber(parseFloat(match), mult);
    });
  }

  const multBtns = document.querySelectorAll<HTMLButtonElement>(".mult-btn");
  const ingredientLabels = document.querySelectorAll<HTMLElement>("#ingredients-list label[data-original]");

  multBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      multBtns.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      const mult = parseInt(btn.dataset.mult || "1", 10);
      ingredientLabels.forEach(label => {
        const original = label.dataset.original || label.textContent || "";
        label.textContent = scaleIngredient(original, mult);
      });
    });
  });

  // ── Cook mode — request wake lock ────────────────────────────────
  const cookModeToggle = document.getElementById("cook-mode") as HTMLInputElement;
  let wakeLock: WakeLockSentinel | null = null;
  cookModeToggle?.addEventListener("change", async () => {
    if (cookModeToggle.checked && "wakeLock" in navigator) {
      try { wakeLock = await navigator.wakeLock.request("screen"); } catch {}
    } else {
      wakeLock?.release();
      wakeLock = null;
    }
  });

  // ── Strikethrough checked ingredients ────────────────────────────
  document.querySelectorAll(".ingredients-list input[type=checkbox]").forEach(cb => {
    cb.addEventListener("change", (e) => {
      const label = (e.target as HTMLElement).nextElementSibling as HTMLElement;
      if (label) label.style.textDecoration = (e.target as HTMLInputElement).checked ? "line-through" : "";
    });
  });

  // ── Print only recipe card ────────────────────────────────────────
  document.getElementById("rc-print-btn")?.addEventListener("click", () => {
    window.print();
  });
</script>

<style>
  .recipe-card {
    border: 1px solid #e5e0d8;
    border-radius: 14px;
    overflow: hidden;
    margin: 40px 0;
    background: #fff;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
    font-family: var(--font-body);
  }

  /* Header */
  .rc-header {
    display: flex;
    gap: 20px;
    padding: 24px;
    border-bottom: 1px solid #eee;
    align-items: flex-start;
    background: var(--color-subscribe-bg);
  }
  .rc-thumb {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 10px;
    flex-shrink: 0;
  }
  .rc-meta { flex: 1; }
  .rc-author { font-size: 0.78rem; color: #888; text-decoration: underline; margin-bottom: 6px; }
  .rc-title {
    font-family: var(--font-heading);
    font-size: 1.45rem;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--color-text);
  }
  .rc-stars { display: flex; align-items: center; gap: 6px; margin-bottom: 12px; }
  .star { font-size: 1rem; color: #ddd; }
  .star.on { color: #f5a623; }
  .rc-votes { font-size: 0.78rem; color: #888; }
  .rc-print {
    border: 1px solid var(--color-primary);
    background: #fff;
    color: var(--color-primary);
    border-radius: 6px;
    padding: 7px 16px;
    font-size: 0.78rem;
    font-family: var(--font-body);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .rc-print:hover { background: var(--color-primary); color: var(--color-primary-text); }

  /* Time Row */
  .rc-times {
    display: flex;
    border-bottom: 1px solid #eee;
  }
  .rc-time-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 14px 10px;
    border-right: 1px solid #eee;
  }
  .rc-time-item:last-child { border-right: none; }
  .rc-time-item .label { font-size: 0.72rem; color: #999; text-transform: uppercase; letter-spacing: 0.05em; }
  .rc-time-item .value { font-size: 0.95rem; font-weight: 700; margin-top: 4px; color: var(--color-text); }

  /* Tag Pills */
  .rc-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 14px 20px;
    border-bottom: 1px solid #eee;
  }
  .rc-tag {
    border-radius: 50px;
    padding: 6px 14px;
    font-size: 0.78rem;
    background: var(--color-accent);
    color: var(--color-accent-text);
  }

  /* Section Nav */
  .rc-nav {
    display: flex;
    border-bottom: 1px solid #eee;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .rc-nav::-webkit-scrollbar { display: none; }
  .rc-nav-item {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 13px 18px;
    font-size: 0.78rem;
    font-weight: 600;
    text-decoration: none;
    color: #555;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
  }
  .rc-nav-item:hover { color: var(--color-primary); border-bottom-color: var(--color-primary); }

  /* Sections */
  .rc-section {
    padding: 24px;
    border-bottom: 1px solid #eee;
  }
  .rc-section:last-child { border-bottom: none; }
  .rc-section h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 400;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--color-text);
  }
  .rc-section h3::after {
    content: "";
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.12;
  }

  /* Equipment */
  .equipment-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 0.9rem;
  }
  .equipment-list a { color: var(--color-links); text-decoration: underline; }

  /* Ingredients */
  .rc-ingredients-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0;
  }
  .rc-ingredients-header h3 { margin-bottom: 0; }
  .serving-toggle { display: flex; gap: 4px; }
  .mult-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: #fff;
    font-size: 0.78rem;
    font-weight: 600;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.2s;
  }
  .mult-btn.active { background: var(--color-primary); color: var(--color-primary-text); border-color: var(--color-primary); }
  .ingredients-list {
    list-style: none;
    padding: 0;
    margin: 14px 0 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ingredients-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.9rem;
    line-height: 1.5;
    color: #444;
    border-bottom: 1px solid #f5f0eb;
    padding-bottom: 10px;
  }
  .ingredients-list li:last-child { border-bottom: none; padding-bottom: 0; }
  .ingredients-list input[type="checkbox"] { margin-top: 3px; flex-shrink: 0; accent-color: var(--color-primary); }

  /* Instructions */
  .rc-method-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0;
  }
  .rc-method-header h3 { margin-bottom: 0; }
  .cook-mode {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    cursor: pointer;
    color: #555;
  }
  .cook-mode small { color: #999; font-size: 0.72rem; }
  .cook-mode input { accent-color: var(--color-primary); }
  .instructions-list {
    margin: 16px 0 0;
    padding-left: 22px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    font-size: 0.92rem;
    line-height: 1.8;
    color: #444;
  }
  .instructions-list li::marker { color: var(--color-primary); font-weight: 700; }
  .step-label {
    color: var(--color-primary);
    font-family: var(--font-body);
    margin-right: 4px;
  }

  /* Video */
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: 0;
  }

  /* Notes */
  .notes-content {
    font-size: 0.9rem;
    line-height: 1.75;
    color: #555;
  }

  @media (max-width: 500px) {
    .rc-header { flex-direction: column; }
    .rc-thumb { width: 100%; height: 200px; }
  }

  /* ── Print: show only the recipe card ───────────────────────────── */
  @media print {
    body * { visibility: hidden; }
    #recipe-card,
    #recipe-card * { visibility: visible; }
    #recipe-card {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      background: #fff;
      box-shadow: none;
      border-radius: 0;
      overflow: visible;
    }
  }
</style>
