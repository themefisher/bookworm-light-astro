---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import CTA from "@/components/CTA.astro";

const allPartners = await getCollection("partners");

// Sort all partners alphabetically first
const sortedPartners = allPartners.sort((a, b) => 
  a.data.title.localeCompare(b.data.title)
);

// Split into Featured and Additional categories 
const featuredPartners = sortedPartners.filter(p => p.data.featured === true);
const additionalPartners = sortedPartners.filter(p => p.data.featured !== true);
---

<Base title="Meet Our Partners">
  <section class="section">
    <div class="container">
      <div class="row md:gx-4 content">
        <div class="col-10 offset-1 md:col-4 md:offset-4 sm:col-8 sm:offset-2">
          <Image src="/images/story-logo.png" alt="STORY Logo" width={800} height={570} />
        </div>
      </div>
      <div class="row my-12">
        <div class="col-12 lg:col-3 xl:col-4 lg:border-r-8 border-primary pt-4">
          <h1 class="border-b-8 lg:text-center lg:border-b-0 border-primary py-4 m-0">STORY Partners</h1>
        </div>
        <div class="col-12 lg:col-9 xl:col-8 prose prose-slate prose-xl max-w-none">
          <p class="mt-0 pt-4 ">
            The STORY partner institutions are committed to participating in our small-town and rural-focused in-person and virtual programming on an ongoing basis. Our academic programs, campus settings, student traditions and application requirements are all distinct. Learn more about each institution on their partner pages below. 
          </p>
        </div>
      </div>

      {featuredPartners.length > 0 && (
        <div class="mb-24">
          <div class="row g-4">
            {featuredPartners.map((partner) => (
              <div class="col-12 sm:col-6 md:col-4 lg:col-3">
                <a href={`/partners/${partner.id}`} class="group block h-full p-6 bg-white border-2 border-primary/10 rounded-xl hover:border-primary transition-all duration-300">
                  <div class="h-32 flex items-center justify-center mb-4">
                    <Image 
                      src={partner.data.logo} 
                      alt={partner.data.title} 
                      width={400} 
                      height={200}
                      class="max-h-full w-auto object-contain transition-transform duration-500 group-hover:scale-110" 
                    />
                  </div>
                  <h3 class="h6 font-bold text-center text-text group-hover:text-primary transition-colors">{partner.data.title}</h3>
                </a>
              </div>
            ))}
          </div>
        </div>
      )}
<!--      <div class="row">
        <div class="col-12">
  <hr class="mt-4 mb-12 border-2 border-story-dark" />
        </div>
      </div> -->
<div class="row mb-16">

        <div class="col-12 lg:col-3 xl:col-4 lg:border-r-8 border-accent-purple pt-4">
          <h1 class="border-b-8 lg:text-center lg:border-b-0 border-accent-purple py-4 m-0">Local Partners</h1>
        </div>
        <div class="col-12 lg:col-9 xl:col-8 prose prose-slate prose-xl max-w-none ">
          <p class="pt-4 ">
            STORY collaborates with institutions that serve the areas we visit through select in-person college fairs and virtual programming. Learn more about these institutions by visiting their websites below. 
          </p>
        </div>
      </div>

      {additionalPartners.length > 0 && (
        <div>
          <div class="row g-4">
            {additionalPartners.map((partner) => (
              <div class="col-12 sm:col-6 md:col-4 lg:col-3">
                <a 
                  href={partner.data.website} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="group block h-full p-6 bg-white border border-gray-200 rounded-xl hover:border-primary transition-all duration-300 shadow-sm"
                >
                  <div class="h-24 flex items-center justify-center mb-4">
                    <Image 
                      src={partner.data.logo} 
                      alt={partner.data.title} 
                      width={300} 
                      height={150}
                      class="max-h-full w-auto object-contain grayscale group-hover:grayscale-0 transition-all duration-500" 
                    />
                  </div>
                  <p class="text-sm font-bold text-center group-hover:text-primary transition-colors">{partner.data.title}</p>
                </a>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
  <CTA />
</Base>