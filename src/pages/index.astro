---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import CTA from "@/components/CTA.astro";

---

<Base>
  <section class="section">
    <div class="container  py-32">
      <div class="row content-center">
        <div class="col-12 md:col-7">
          <Image src="/images/story-logo.png" alt="A bird." width="800" height="570" />
        </div>
        
        <div class="col-12 md:col-5 content-center">
          <h1>Welcome to STORY</h1>
          <p class="py-4 text-lg">The STORY Consortium is committed to empowering rural & small-town students – and the communities that support them – by preparing them for the college search and application process, with an aim of expanding access to higher education.</p>
          <a href="/about" class="btn btn-primary mt-2 no-underline uppercase hover:bg-secondary hover:border-secondary hover:text-text">
            About STORY
          </a>
        </div>
      </div>
    </div>
  </section>
  <section class="section bg-primary">
    <div class="container py-16">
      <div class="row">
      <div class="col-12 sm:col-5">
        <h2 class="text-light">Meet Our Partners</h2>
      </div>
      
      <div class="col-12 sm:col-7">
        <p class="pb-4 text-light text-lg">The STORY Consortium is committed to empowering rural & small-town students – and the communities that support them – by preparing them for the college search and application process, with an aim of expanding access to higher education.</p>
        <a href="/partners" class="btn btn-primary mt-2 no-underline uppercase hover:bg-secondary hover:border-secondary hover:text-text">
          STORY Partners
        </a>
      </div>
    </div>
    </div>
    </section>
    <section class="section">
      <div class="container content  py-16">
        <div class="row ">
          <div class="col-12 md:col-8 md:offset-2 mb-8">
            <h2 class="text-center">Visit STORY</h2>
          </div>
          <div class="col-12 md:col-6">
            <a href="#" class="block hover:text-primary overflow-hidden group">
              <Image src="https://placehold.co/600x400" alt="placeholder" width="600" height="400" class="group-hover:scale-[1.03] transition duration-300 w-full"/></a>
            <h3>
              <a href="/in-person-events" class="hover:text-primary transition-duration-300">In-person Events</a>
            </h3>
            <p class="my-4">Learn more about which region we will travel to next (and where we have been previously).</p>
          </div>
          <div class="col-12 md:col-6">
            <a href="#" class="block hover:text-primary overflow-hidden group">
              <Image src="https://placehold.co/600x400" alt="placeholder" width="600" height="600" class="group-hover:scale-[1.03] transition duration-300 w-full" />
            </a>
            <h3>
              <a href="/virtual-events" class="hover:text-primary transition-duration-300">Virtual Events</a>
            </h3>
            <p class="my-4">Explore specific topics and partner institutions through our virtual programming.</p>
          </div>
        </div>
      </div>
    </section>

    <CTA />
</Base>
